# Copy to `.env` in the repo root and fill in secrets. `.env` is gitignored.

# Required for API calls (see https://platform.openai.com/api-keys )
OPENAI_API_KEY=

# Models — only these three lines control analyze / validate / refactor.
# Experiment A (nano analyze+validate, mini refactor):
#   OPENAI_MODEL_ANALYZE=gpt-5.4-nano
#   OPENAI_MODEL_VALIDATE=gpt-5.4-nano
#   OPENAI_MODEL_REFACTOR=gpt-5.4-mini
# Experiment B (same, but full gpt-5.4 for refactor):
#   OPENAI_MODEL_REFACTOR=gpt-5.4
OPENAI_MODEL_ANALYZE=gpt-5.4-nano
OPENAI_MODEL_VALIDATE=gpt-5.4-nano
OPENAI_MODEL_REFACTOR=gpt-5.4-mini

# OpenAI generation (optional; passed as max_completion_tokens for chat completions)
OPENAI_MAX_TOKENS_JSON=8192
OPENAI_MAX_TOKENS_REFACTOR=16384
OPENAI_TEMPERATURE=0.2

# Optional: per-model USD prices (per 1M tokens) for metadata estimated_cost_* — keys must match model ids exactly.
# Rates below match OpenAI list pricing for prompt (input) and completion (output). Cached-input pricing is not applied (usage would need a cache breakdown).
# OPENAI_MODEL_PRICES_JSON={"gpt-5.4":{"prompt_per_million_usd":2.5,"completion_per_million_usd":15.0},"gpt-5.4-mini":{"prompt_per_million_usd":0.75,"completion_per_million_usd":4.5},"gpt-5.4-nano":{"prompt_per_million_usd":0.2,"completion_per_million_usd":1.25}}

# Pipeline paths and limits (optional)
DESIGN_AWARE_DATASET=design_issues.json
DESIGN_AWARE_PROMPTS_DIR=prompts
DESIGN_AWARE_RUNS_DIR=runs
# Optional: batch folder so two experiments do not overwrite (outputs: runs/<subdir>/<snippet_id>/).
# Batch with gpt-5.4-mini refactor: DESIGN_AWARE_RUNS_SUBDIR=gpt5.4mini_refactoring
# Batch with gpt-5.4 refactor: DESIGN_AWARE_RUNS_SUBDIR=gpt5.4_refactoring
# DESIGN_AWARE_RUNS_SUBDIR=
DESIGN_AWARE_MAX_REFACTOR_RETRIES=2
DESIGN_AWARE_RECURSION_LIMIT=40
